{
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.git": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": false 
  },
  "html.validate.scripts": false,
  "html.validate.styles": false,
  "liveServer.settings.ignoreFiles": [
    "**/node_modules/**",
    "**/.git/**",
    "**/js/data/business-hours.js",
    "**/sitemap.xml",
    "**/.DS_Store",
    "**/*.log",
    "**/scratch/**",
    "**/database/**",
    "**/dist/**",
    "**/seo_tracking/**",
    "**/.vscode/**",
    "**/_templates/**",
    "**/scripts/**",
    "**/*.md",
    "**/*.json",
    "**/.gemini/**",
    "**/.history/**",
    "**/package-lock.json",
    "**/.env*"
  ]
}
